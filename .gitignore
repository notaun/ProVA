# ── Credentials — NEVER commit these ──────────────────────────────
.env

# ── Virtual environment ────────────────────────────────────────────
.venv/
venv/
env/

# ── Python cache ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

